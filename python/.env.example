# Copy this file to `.env` and fill in your values.

# From your Slack app → "OAuth & Permissions" (starts with xoxb-)
SLACK_BOT_TOKEN=xoxb-...

# From your Slack app → "Basic Information" → App-Level Tokens (starts with xapp-)
# Needs the connections:write scope. Required for Socket Mode.
SLACK_APP_TOKEN=xapp-...

# Optional. Folder where YOUR twin lives (the one with CLAUDE.md + handbook).
# Defaults to the parent folder of this module. Set it if the module lives
# somewhere else.
# TWIN_DIR=/absolute/path/to/your-twin

# Optional. Max time for one reply, in milliseconds (default 5 minutes).
# CLAUDE_TIMEOUT_MS=300000
